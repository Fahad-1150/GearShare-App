# SSL Medo Configuration
# This file contains your SSL Medo (sslcommerz) payment gateway credentials
# 
# ⚠️ SECURITY WARNING: Never commit this file to version control!
# Add this file to .gitignore before pushing to repository

# Your SSL Medo Store ID
# Get this from your SSL dashboard
SSL_STORE_ID=YOUR_STORE_ID

# Your SSL Medo Store Password
# Get this from your SSL dashboard
SSL_STORE_PASSWORD=YOUR_STORE_PASSWORD

# Use test/demo mode for development
# Set to true for sandbox testing, false for production
SSL_TEST_MODE=true

# Test Store ID (if using demo/test store)
# Optional: Use this if SSL provides a separate test store ID
SSL_TEST_STORE_ID=testbox

# Test Store Password (if using demo/test store)
# Optional: Use this if SSL provides a separate test password
SSL_TEST_STORE_PASSWORD=testpass

# App Domain for Callbacks
# Update this to your actual domain in production
APP_DOMAIN=https://gearshare.app

# Enable Debug Logging
# Set to true to see detailed payment logs
DEBUG_PAYMENT=true
